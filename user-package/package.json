{
  "name": "email-sender-desktop",
  "version": "1.0.0",
  "description": "Email Sender Desktop Application",
  "main": "main.js",
  "scripts": {
    "electron": "electron .",
    "electron-dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "dev": "vite dev --host localhost --port 5173",
    "build": "vite build --mode production",
    "build-electron": "npm run sync-styles && npm run build && electron-builder --dir",
    "dist": "npm run sync-styles && npm run build && electron-builder --publish=never",
    "dist-fast": "electron-builder --dir --config.compression=store",
    "preview": "vite preview --host localhost --port 4173",
    "sync-styles": "node sync-styles.js",
    "sync-and-build": "node sync-styles.js && npm run build"
  },
  "dependencies": {
    "axios": "^1.9.0",
    "nodemailer": "^6.9.7",
    "electron": "^32.1.2"
  },
  "peerDependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.15",
    "@tailwindcss/vite": "^4.1.3",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.17",
    "typescript": "5.6.3",
    "vite": "^5.4.19",
    "concurrently": "^9.0.1",
    "wait-on": "^8.0.1",
    "electron-builder": "^25.1.7"
  },
  "build": {
    "appId": "com.emailsender.desktop",
    "productName": "Email Sender Desktop",
    "directories": {
      "output": "dist-electron",
      "buildResources": "assets"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "files",
        "to": "files",
        "filter": ["**/*"]
      },
      {
        "from": "config",
        "to": "config",
        "filter": ["**/*"]
      }
    ],
    "compression": "normal",
    "asar": true,
    "asarUnpack": [
      "node_modules/nodemailer/**/*"
    ]
  }
}